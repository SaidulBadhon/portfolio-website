# Backend API (Bun + Hono server)
# Used by server components/SSR
API_URL=http://localhost:4000

# Optional: used by client-side dashboard/API calls
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dashboard auth – set a password to protect /dashboard
DASHBOARD_PASSWORD=your-secret-password

# Optional: Google Gemini for "Generate with AI" in project form (get key at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
